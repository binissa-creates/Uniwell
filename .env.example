# Root .env — used ONLY by local server-side scripts (e.g. scripts/seed-admins.js).
# Never commit the real values. Never ship these to the frontend bundle.
#
# Supabase Dashboard -> Project Settings -> API

SUPABASE_URL=https://<project-ref>.supabase.co

# service_role key — bypasses RLS. Keep strictly server-side.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...
